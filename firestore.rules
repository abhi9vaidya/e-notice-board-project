rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Profiles Collection
    match /profiles/{userId} {
      // Anyone authenticated can read profiles (to show names)
      allow read: if isAuthenticated();
      // Users can only create/update their own profile
      allow write: if isOwner(userId);
    }

    // Notices Collection
    match /notices/{noticeId} {
      // Anyone can read active, non-archived notices (for the public TV display)
      allow read: if true;
      
      // Only authenticated users (faculty/admin) can create, update, or delete notices
      allow create: if isAuthenticated() && request.resource.data.facultyId == request.auth.uid;
      // Allow updates/deletes if the user created the notice OR if they are an admin
      allow update, delete: if isAuthenticated() && (resource.data.facultyId == request.auth.uid || get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin');
    }
  }
}
