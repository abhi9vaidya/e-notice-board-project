rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Checks Firestore for admin role (used sparingly to avoid extra reads)
    function isAdmin() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Profiles ─────────────────────────────────────────────────────────────

    match /profiles/{userId} {
      // Any authenticated faculty/admin can read profiles (for notice attribution etc.)
      allow read: if isAuthenticated();

      // Self-create: allowed only if the email is in the admin-managed allowlist.
      // Since the admin pre-approved the email, the profile is created as 'approved'.
      // Role is locked to 'faculty' on self-create.
      allow create: if isOwner(userId)
        && request.resource.data.role == 'faculty'
        && request.resource.data.status == 'approved'
        && exists(/databases/$(database)/documents/allowlist/$(request.resource.data.email));

      // Self-update: allowed, BUT a user cannot change their own role OR status
      // Admin-update: admins can change any field including role and status
      allow update: if
        (isOwner(userId)
          && request.resource.data.role == resource.data.role
          && request.resource.data.status == resource.data.status)
        || isAdmin();

      // Only admins can delete profiles
      allow delete: if isAdmin();
    }

    // ── Allowlist ─────────────────────────────────────────────────────────────
    // Document ID = lowercase faculty email. Fields: { department?: string, addedAt: timestamp }

    match /allowlist/{email} {
      // Any authenticated user can read (needed for the allowlist check during login)
      allow read: if isAuthenticated();

      // Only admins can add or remove emails from the allowlist
      allow create, update, delete: if isAdmin();
    }

    // ── Notices ──────────────────────────────────────────────────────────────

    match /notices/{noticeId} {
      // Public read (TV display etc.)
      allow read: if true;

      // Create: authenticated user whose facultyId matches their own uid
      allow create: if isAuthenticated()
        && request.resource.data.facultyId == request.auth.uid;

      // Update / delete: own notice  OR  admin
      allow update, delete: if isAuthenticated()
        && (
          resource.data.facultyId == request.auth.uid
          || get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin'
        );
    }
  }
}
