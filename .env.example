# ─────────────────────────────────────────────────────────────────
#  E-Notice Board – Environment Variables
#  Copy this file to .env and fill in your own values.
#  NEVER commit your .env file – it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────

# ── Firebase ──────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your Apps → Web App
VITE_FIREBASE_API_KEY="your-api-key-here"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="1:your-sender-id:web:your-app-id"
VITE_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"

# ── Cloudinary (free image hosting) ──────────────────────────────
# Setup: cloudinary.com → free account → Settings → Upload → Upload Presets → Add (Unsigned)
VITE_CLOUDINARY_CLOUD_NAME="your-cloud-name"
VITE_CLOUDINARY_UPLOAD_PRESET="your-unsigned-preset-name"

# ── Google Drive Proxy ────────────────────────────────────────────
# See docs/drive_proxy.gs for setup instructions.
# Deploy the Apps Script as a Web App and paste the URL here.
VITE_GOOGLE_DRIVE_PROXY_URL="https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec"

# ── Gemini AI (free — for PDF/image text extraction) ──────────────
# Get a free API key (no billing needed) at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY="your-gemini-api-key-here"
